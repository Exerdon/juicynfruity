    flex-direction: column;
  } }

  div {
    display: flex;
    justify-content: flex-start;
    align-items: center;
    gap: 12px;
    
    @media screen and (max-width: 500px) { & {
      margin-bottom: 8px;
    } }
  }

  span {
    border-width: 1px;
