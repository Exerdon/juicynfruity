`,yJ=pZ.Ay.div`
  box-sizing: border-box;
  background-color: #fff;
  border-radius: 4px;
  margin: auto auto;
  height: 100%;
  width: 100%;
  display: flex;
  flex-direction: column;
  position: relative;

  .wBox-upper {
    position: absolute;
    left: 0;
    top: 0;
    right: 50px;
    height: 79px;
  }

  > div { flex: 1 1 auto; min-height: 0; }

  @media screen and (max-width: 480px) {
    border-radius: 0;
  }
`,yX=pZ.Ay.div`
  @font-face {
