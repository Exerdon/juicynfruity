class WhatsAppButton{constructor(){this.number=JFCustomWidget.getWidgetSetting("whatsAppNumber"),this.messageText=JFCustomWidget.getWidgetSetting("messageText"),this.alignment=JFCustomWidget.getWidgetSetting("alignment")||"left",this.btnText=JFCustomWidget.getWidgetSetting("buttonText"),this.linkElem=document.querySelector(".whatsapp-link"),this.btnTextWrapper=document.querySelector(".btn-text"),this.readFields=[],this.server="https://dev-app-widgets.jotform.io/titus/whatsAppButton"}url(){const t="https://wa.me",e=""!==this.number?"/"+encodeURIComponent(this.number):"",n=""!==this.messageText&&""!==this.number?"/?text="+encodeURIComponent(this.messageText):"";return`${t}${e}${n}`}applySettings(){this.linkElem.href=this.url(),this.btnTextWrapper.innerText=this.btnText,document.body.setAttribute("data-alignment",this.alignment.toLowerCase())}getFormName(){var t=new Headers;t.append("Content-Type","application/x-www-form-urlencoded");var e=new URLSearchParams;e.append("action","formTitle"),e.append("formID",""),e.append("token","");var n={method:"POST",headers:t,body:e,redirect:"follow"};fetch("",n).then(t=>t.text()).then(t=>console.log(t)).catch(t=>console.log("error",t))}}JFCustomWidget.subscribe("ready",function(){var t=new WhatsAppButton;t.applySettings()});