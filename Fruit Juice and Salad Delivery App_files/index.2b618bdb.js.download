  .withIconItemContent {
    display: flex;
    align-items: center;
    background-color: #fff;
    border: 1px solid #D3DCEF;
    border-radius: 4px;
    padding: 5px 11px 5px 5px;

    & > div:first-of-type {
      margin: 0;

      svg { fill: #FF6100}
    }
  }

  .itemContent {
    display: flex;
    text-align: left;
    flex-grow: 1;
    overflow: hidden;
    align-items: center;
    margin-left: 5px;

    .title {
      margin: 0;
      padding: 0;
      max-width: 100%;
      font-size: 15px;
      line-height: 20px;
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      color: ${m.k9};
      display: block;
      font-weight: 500;
