  .tags-input {
    .tagify {
      min-height: 44px;
      display: flex;
      overflow: hidden;
      flex-wrap: nowrap;
      border-radius: 4px;
      align-items: center;
      background-color: #434A60;
      border: 1px solid #292D3C;
      .tagify__input {
        flex: 1;
        min-width: 0;
        overflow: hidden;
        line-height: 44px;
        white-space: nowrap;
        display: inline-block;
        padding: 7px 44px 5px 12px !important;
        text-overflow: ellipsis;
        &::before {
          color: #BFBFBF;
        }
        > br {
          display: none;
        }
        .tagify__tag {
            gap: 4px;
            top: 2px;
            height: 24px;
            margin: 0 2px;
            cursor: pointer;
            border-radius: 4px;
            display: inline-flex;
            padding: 2px 8px 2px 6px;
            &::before {
              content: '';
              width: 18px;
              height: 18px;
              background-repeat: no-repeat;
              background-position: center;
              background-image: url(${e=>Y[e.columnType]||Y[p.aW.TEXT]});
            }
            &::after {
              inset: 0;
              content: '';
              z-index: -1;
              position: absolute;
              border-radius: 4px;
              background-color: #D3D6DE;
            }
            &:hover {
              div:before {
                top: 0 !important;
                bottom: 0 !important;
                box-shadow: none !important;
                border-radius: 4px;
              }
            }
            &.tagify__tag-highlighted::after {
              background-color:rgb(131, 136, 151);
            }
            .tagify__tag__removeBtn {
              &:before {
                width: 18px;
                height: 18px;
                background: url('data:image/svg+xml;base64,');
              }
            }
            div {
              margin: 0;
              padding: 0;
                &::before {
                  top: 0;
                  bottom: 0;
                  border-radius: 4px;
                }
            }
            .tagify__tag-text {
              font-size: 14px;
              color: #33384A;
              line-height: 20px;
            }
        }
      }
    }
  }
  .formFields {
    position: relative;
    button.formFields-button {
        &::before {
          content: '';
          width: 1px;
          height: 23px;
          background-color: #4C536F;
        }
        right: 0px;
        padding: 0;
        width: 38px;
        height: 42px;
        position: absolute;
        background-repeat: no-repeat !important;
        background-position: center !important;
        top: -43px !important;
        // top: calc(-1 * max(var(--dynamic-tag-input-height, 43px), 43px)) !important;
        background: url('data:image/svg+xml;base64,');
      .formFields-icon-wrapper {
        display: none;
      }
      .formFields-text {
        display: none;
      }
    }
    .formFields-popover {
      left: 0;
      width: 100%;
      padding: 4px;
      transform: none;
      border-radius: 4px;
      margin-top: 4px !important;
      background-color: #434A60;
      box-shadow: 0 16px 24px 0 rgba(10, 11, 13, 0.32), 0 2px 8px 0 rgba(10, 11, 13, 0.04);
      .formFields-wrapper {
        .formFields-row.forSearch {
          display: none;
        }
        .formFields-select {
          padding: 0;
          max-width: 100%;
          .formFields-header {
            display: none;
          }
          .formFields-empty {
            margin: 0;
            padding: 12px 0;
          }
          ul {
            margin: 0;
            .formFields-option {
              padding: 0 12px;
              max-width: 100%;
              position: relative;
              &:hover {
                background-color: #393E51;
              }
              &::before {
                content: '';
                width: 18px;
                height: 18px;
                background-repeat: no-repeat;
                background-position: center;  
                background-image: url(${e=>J[e.columnType]||J[p.aW.TEXT]});
              }
              .formFields-option-content {
                padding: 12px;
                .formFields-option-text {
                  color: #FFFFFF;
                }
              }
            }
            ${e=>e.selectedFields&&e.selectedFields.map(e=>`
                  .formFields-option[data-value="${e}"]::after {
                    content: '';
                    top: 8px;
                    right: 16px;
                    width: 20px;
                    height: 20px;
                    position: absolute;
                    background-repeat: no-repeat;
                    background-position: center;
                    background-image: url("data:image/svg+xml;base64,");
                  }
                `).join("\n")}
          }
        }
      }
      .formFields-create-field {
        margin-top: 2px;
        padding-top: 2px;
        border-top: 1px solid #4C536F;
        button {
          gap: 12px;
          width: 100%;
          height: 40px;
          display: flex;
          padding: 12px;
          font-size: 14px;
          border-radius: 4px;
          align-items: center;

          &:hover {
            background-color: #393E51;
          }
        }
      }
    }
  }
