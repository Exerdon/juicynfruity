  }

  .right-preview-enter-active {
    opacity: 1;
    margin-right: 0;
    transition: all 300ms;
  }
  .right-preview-enter-done {
    margin-right: 0;
    opacity: 1;
    transition: all 300ms;
  }

  .right-preview-exit {
    opacity: 1;
  }

  .right-preview-exit-active {
    opacity: 0;
    margin-right: -${o.Ay.rightPanel}px;
    transition: all 300ms;
  }

  .right-preview-exit-done {
    opacity: 0;
    margin-right: -${o.Ay.rightPanel}px;
    transition: all 300ms;
  }

  .right-panel-container {
    width: 410px;
    overflow: hidden;
    height: 100%;
