      .fileUpload {
        height: 156px;
        background-color: var(--jfv-panel-right-item-background);

        input {
          width: 1px;
          padding: 0;
          font-size: 12px;
          top: 0;
          opacity: 0;
          pointer-events: none;
        }
        &-verticalAlign {
          &-text {
            font-size: 14px;
          }
          form#myForm {
            .fileUploadLabel {
              padding: 15px 30px 15px 15px;
              & > span {
                &::before {
                  margin: -3px 17px -3px 2px;
                }
              }
            }
          }
        }
      }

      div[data-tabid="link"] {
        label {
          width: 100%;
        }

        .line {
          display: flex;
          justify-content: right;

          a.btn {
            height: 38px;
            padding: 0.625em;
            cursor: pointer;
            display: flex;
            justify-content: center;
            align-items: center;
            text-transform: uppercase;
            min-width: 112px;
          }
        }
      }
    }
  }
