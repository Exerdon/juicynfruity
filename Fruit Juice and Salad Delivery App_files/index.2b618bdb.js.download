    .skeleton {
        position: relative;
        background-color: var(--neutral-100) !important;
        border-radius: var(--radius-md);
        overflow: hidden;
    }

    .skeleton::before {
        content: '';
        position: absolute;
        top: 0;
        left: -100%;
        width: 200%;
        height: 100%;
        background: linear-gradient(90deg, transparent 0%, 
            color-mix(in srgb, var(--bg-surface) 60%, transparent) 50%, transparent 100%);
        animation: shimmer 2s infinite;
    }

    @keyframes shimmer {
        0% {
            transform: translateX(-100%);
        }

        100% {
            transform: translateX(100%);
        }
    }
`,i=n(89760),a=n(4519),l=n(12614);let s='Circular,-apple-system,BlinkMacSystemFont,"Segoe UI",Roboto,Helvetica,Arial,sans-serif,"Apple Color Emoji","Segoe UI Emoji","Segoe UI Symbol"',c=(0,r.AH)`
  &::-webkit-scrollbar {
    width: var(--jfv-panel-scrollbar-width);
  }

  &::-webkit-scrollbar-thumb {
    background: var(--jfv-panel-scrollbar-thumb);
  }

  &::-webkit-scrollbar-thumb:hover {
    background: var(--jfv-panel-scrollbar-thumb-hover);
  }
`;(0,r.AH)`
  &::-webkit-scrollbar-track {
    background-color: var(--jfv-left-panel-background);
    border-left: var(--jfv-left-panel-scrollbar-border);
  }
`;let d=(0,r.AH)`
  &::-webkit-scrollbar-track {
    background-color: var(--jfv-right-panel-background);
    border-left: var(--jfv-right-panel-scrollbar-border);
  }
`,u=(0,r.DU)`

  html{
    height: 100%;
    overscroll-behavior: none;

    &:not(.public-html){
      overflow: hidden;
    }
  }
  body {
    height: 100%;
    color: ${i.k9};

    &:not(.public-body){
      overflow: hidden;
    }
  }
  .portalApp:has(.selected-element-header):not(.scrollingDown) {
    .subHeader-vc {
     margin-bottom: -46px
    }
  }
  .portalApp:has(.selected-element-header:not(.is-closing)) {
    .portal-element:not([aria-selected="true"]),
    .appHeader {
      opacity: 0.5;
    }
  }
  .formPage:has(.list-item-edit-page) {
    > section:first-child {
      position: fixed;
    }
    iframe {
      padding-top: 65px;
    }
  }
  .pageStageContainer {
    &.streaming {
      height: 100%;
    }
    &.isEditableTextFocused {
      height: 100%;
    }
    &:not(:has(.bottom-navigation-wrapper)) {
      // height: 100%;
    }
  }

  .list-item-edit-page {
    height: 100dvh;
  }
  @media screen and (max-width: 480px) {
    .list-item-edit-page {
      height: calc(100dvh - 65px);
    }
    .portalApp:has(.bottom-navigation-wrapper) {
      .list-item-edit-page {
        height: calc(100dvh - 70px);
        padding-bottom: 70px;
      }
    }
    ${(0,a.G7)(l.K7.CopilotV2)&&(0,r.AH)`
      .portalApp:has(.ai-agent-chat-animation-container.isOpened) {
        --portal-data-layer-header: 0px;
        .jNewHeader,
        .multi-page-navigation-bar,
        .panelToggle-wrapper {
          display: none;
        }
      }
    `}
  }
  .qrImageWrapper {
    .qrCodePreview {
      margin: 60px 72px 60px;
      box-shadow: 0 16px 24px 0 rgba(0, 0, 0, 0.16), 0 2px 8px 0 rgba(0, 0, 0, 0.04);
    }
  }
  .qr-text {
    width: 88px;
    text-align: center;
  }
  .portalApp:has(.jfBrandingFooter){
    .qr-code-preview {
      bottom: 64px;
    }
  }
  .isMobilePreview {
    * {
      cursor: url('data:image/png;base64,') 15 15, auto !important;
      &:active {
        cursor: url('data:image/png;base64,') 15 15, auto !important;
      }
    }

    .page {
      display: block;
      margin-bottom: 0;
    }

    &:has(.bottom-navigation-wrapper) .page .scrollableItemListWrapper {
      padding-bottom: 0;
    }

    .router {
      height: auto;
    }

  }
  #root, .portalApp, .portalApp > div { height: 100%; }
  @media (max-width: 768px) {
    .portalApp.isMobileView {
      --portal-mobile-bottom-bar-offset: 0px;
    }

    .portalApp.isMobileView.needStreamingPadding-yes:has(.panel-bottom-bar.panel-bottom-bar--new:not(.mobile-app-designer-bar)) {
      --portal-mobile-bottom-bar-offset: calc(116px + env(safe-area-inset-bottom, 0px));
    }

    .portalApp.isMobileView.needStreamingPadding-yes:has(.panel-bottom-bar.panel-bottom-bar--new.without-podo:not(.mobile-app-designer-bar)),
    .portalApp.isMobileView.needReducedPadding-yes:has(.panel-bottom-bar-minimal-voice-shell) {
      --portal-mobile-bottom-bar-offset: calc(72px + env(safe-area-inset-bottom, 0px));
    }

    .portalApp.isMobileView:has(.panel-bottom-bar.panel-bottom-bar--new.mobile-app-designer-bar),
    .portalApp.isMobileView:has(.mobile-app-designer-nav) {
      --portal-mobile-bottom-bar-offset: 0px;
    }

    .portalApp.isMobileView > div {
      padding-bottom: 0;
    }

    .portalApp.isMobileView .mainStage {
      box-sizing: border-box;
      padding-bottom: var(--portal-mobile-bottom-bar-offset);
      scroll-padding-bottom: var(--portal-mobile-bottom-bar-offset);
    }

    .portalApp.isMobileView .mainStage:has(.appStage) {
      padding-bottom: 0;
    }

    .portalApp.isMobileView .mainStage .appStage {
      box-sizing: border-box;
      padding-bottom: var(--portal-mobile-bottom-bar-offset);
      scroll-padding-bottom: var(--portal-mobile-bottom-bar-offset);
    }
  }
  #root {
    -webkit-overflow-scrolling: touch;
  }

  .portalApp {
    /* Persistent Data iframe (Builder Data tab) — see Data.styles.js */
    --portal-data-layer-header: 64px;
    --portal-data-layer-subheader: 44px;

    .jNewHeader {
      transition: transform 0.3s ease-out, margin-bottom 0.3s ease-out;
    }

    &.scrollingDown {
      --portal-data-layer-header: 0px;
      .jNewHeader {
        pointer-events: none;
        transform: translateY(-64px);
        margin-bottom: -64px;
      }
      .leftPanelContainer {
        padding-bottom: 40px;
      }
    }
  }

  .portalApp:not(:has(.jNewHeader)) {
    --portal-data-layer-header: 0px;
  }

  .portalApp:has(.jNewHeader.isPortal.isPreview) {
    --portal-data-layer-header: 0px;
  }

  @media screen and (max-width: 480px) {
    .portalApp {
      --portal-data-layer-subheader: 40px;
    }
  }

  .portalApp div[tabindex="-1"]:not([class]) {
    flex: 1 1 auto;
    min-height: 0;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    height: 100%;
    position: relative;
  }

  .portalApp [class*="portalApp-"] { height: 100%; overflow-y: auto; }
  .jNewHeader-col.jNewHeader-titleWrapper h1.jNewHeader-title { font-weight: 400; }
  .jNewHeader.isPortal.isPreview {
    height: 0;
    opacity: 0;
    pointer-events: none;
    transition: .3s all ease;
  }

  div.jNewHeader-col.jNewHeader-rightWrapper.alignRight {
    button.quickQR {
      display: none;
    }

    button.cloneApp {
      height: 32px;
      margin-right: 8px;

      svg {
        width: 20px;
        height: 20px;
      }

      &::before {
        content: "Admin Only";
        position: absolute;
        top: -6px;
        right: 0;
        padding: 1.5px 10px;
        background: red;
        border-radius: 10px;
        font-size: 10px;
        color: #FFF;
      }

      @media screen and (max-width: 767px) {
        padding: 0;
        width: 32px;

        svg {
          width: 16px;
          height: 16px;
        }

        &::before {
          display: none;
        }
      }

      @media screen and (max-width: 480px) {
        &::before {
          display: none;
        }
      }
    }

    .jNewHeader-avatar {
      height: 100%; 

      .jNewHeader-avatarContainer {
        height: 100%; 
      }
    }

  }

  @media screen and (max-width: 480px) {
    div.jNewHeader-col.jNewHeader-rightWrapper.alignRight {
      display: flex;
      align-items: center;

      button.quickQR {
        display: inline-flex;
      }
    }
  }

  h1, h2, h3, h4, h5, h6, p { margin: 0; }
  ul { margin: 0; padding: 0; list-style: none; }

  ::placeholder { color: #9e9fb7; }
  .revisionIcon { width: 0; }
  button.jfFeedbackButton {
    z-index: 3 !important;
  }

  .jfFeedbackButton.u-appBuilder {
    border-radius: 11px 11px 0 0;
    width: 170px;
    max-width: 300px;

    &.u-bottomRight {
      bottom: 0;

      +.jfFeedbackButton-modal {
        bottom: 60px;
      }
    }

    &.jFisActive,
    &:hover {
      border-radius: 11px 11px 0 0;

      .jfFeedbackButton-icon {
        opacity: 1;
      }

      .jfFeedbackButton-text {
        padding: 0;
      }
    }

    .jfFeedbackButton-icon.u-appBuilder {
      display: inline-block;
      background-image:  url("https://cdn.jotfor.ms/assets/img/cardforms/feedbackButton.svg");
      background-position: 50% 56%;
      background-size: 18px;
      background-repeat: no-repeat;
    }

    .jfFeedbackButton-text {
      font-size: 16px;
      color: #282e42;
    }
  }

  .router {
    top: 0;
    left: 0;
    bottom: 0;
    right: 0;
  }

  // TODO @Buri, remove top and bottom when new builder opened.
  .page {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 0;
    display: flex;
    overflow-y: auto;
    align-items: center;
    justify-content: center;

    &.showTopBar {
      padding-top: 65px;
    }

    &.shouldShowProgressBar {
      padding-top: 110px;
    }
  }
  
  .stickyNavigationBar + .page {
    padding-top: 0;
  }

  .location-enter .formPage {
    transform: translateX(100%);
    z-index: 1;
  }

  .location-enter.location-enter-active .formPage {
    transform: translateX(0%);
    transition: all 500ms;
  }

  .location-exit.location-exit-active .formPage {
    transform: translateX(100%);
    transition: all 500ms;
  }

  .location-enter .page {
    transform: translateX(-100%);
    z-index: 1;
  }

  .location-enter.location-enter-active .page {
    transform: translateX(0%);
    transition: all 500ms;
  }

  .location-exit.location-exit-active .page {
    transform: translateX(-100%);
    transition: all 500ms;
  }

  .slide-up-enter.portalApp-select {
    transform: translateY(100%);
    opacity: 0;
  }

  .slide-up-enter.slide-up-enter-active.portalApp-select {
    transform: translateY(0%);
    opacity: 1;
    transition: all 500ms;
  }

  .slide-up-exit.portalApp-select {
    transform: translateY(-100%);
    opacity: 1;
  }

  .slide-up-exit.slide-up-exit-active.portalApp-select {
    transform: translateY(0%);
    opacity: 0;
    transition: all 500ms;
  }

  .slide-up-enter.portalApp-previewSplash {
    transform: translateY(-100%);
    opacity: 0;
  }

  .slide-up-enter.slide-up-enter-active.portalApp-previewSplash {
    transform: translateY(0%);
    opacity: 1;
    transition: all 500ms;
  }

  .slide-up-exit.portalApp-previewSplash {
    position: absolute;
    transform: translateY(0%);
    opacity: 1;
  }

  .slide-up-exit.slide-up-exit-active.portalApp-previewSplash {
    transform: translateY(-100%);
    opacity: 0;
    transition: all 500ms;
  }

  .mobileCtxMenu-enter {
    opacity: 0;
    transition: all 400ms;
  }

  .mobileCtxMenu-enter-active {
    opacity: 1;
  }

  .mobileCtxMenu-enter-done {
    opacity: 1;
  }

  .mobileCtxMenu-exit {
    opacity: 1;
    transition: all 400ms;
  }

  .mobileCtxMenu-exit-active {
    opacity: 0;
  }

  .mobileCtxMenu-exit-done {
    opacity: 0;
  }

  .toast-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    height: 100%;
    background: rgba(10, 21, 81, 0.4);
    pointer-events: all;
    user-select: none;
    overflow: hidden;
    z-index: 1101;

    &-appear {
      opacity: 0;
      &-done {
        opacity: 1;
        transition: .3s opacity;
      }
    }
  }

  .Toastify__toast-container--top-right:has(div.clonePreventedFormsToast) {
    width: 400px;
    left: auto;

    .clonePreventedFormsToast {
      background-color: transparent !important;
    }

    @media screen and (max-width: 480px) {
      width: 344px;

      .clonePreventedFormsToast {
        margin: 0 !important;
        background-color: transparent !important;
      }
    }
  }

  #builderPortalToaster {
    .Toastify  {
      &__toast {
        &--default {
          background-color: #252D5B;
          padding: 0;

          @media screen and (max-width: 480px) {
            border-radius: 4px;
          }
        }

        &-body {
          padding: 0;
        }

        &-container {
          padding: 0;
        }

        &-container--top-right {
          top: 130px;
          right: 15px;
        }
        
        &-container--top-center {
          @media screen and (max-width: 480px) {
            top: 80px;
            width: 100%;
            padding: 0 5%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
          }
        }
      }
    }
  }

  #publicPortalToaster {
    .Toastify  {
      &__toast {
        &--default {
          background-color: #fff;
          padding: 0;

          @media screen and (max-width: 480px) {
            margin: 0;
            border-radius: 4px;
          }
        }

        &-body {
          padding: 0;
        }

        &-container {
          padding: 0;
        }

        &-container--top-right {
          top: 80px;
          right: 15px;
        }
        
        &-container--top-center {
          @media screen and (max-width: 480px) {
            top: 80px;
            width: 100%;
            padding: 0 5%;
            display: flex;
            justify-content: center;
            align-items: center;
            margin: 0;
          }
        }
      }
    }
  }

  #preview-content {
    .jPreview-close {
      top: 12px;
    }

    .jPreview-header {
      background-color: #252D5B;
      height: 64px;
      border-radius: 0;

      .jPreviewButton {
        &-fileSize {
          display: none;
        }
        &.forDownload span {
          pointer-events: none;
        }
      }

      .jPreview-fileDesc {
        font-size: 14px;
        line-height: 18px;
      }
      .jPreview-fileThumbnailBox {
        svg { width: 24px; height: 24px; }
      }
    }

    .jPreview-zoomContainer {
      button {
        svg {
          color: #fff;
          width: 24px;
          height: 24px;
        }
      }
    }

    .react-pdf__Document {
      max-width: 100%;
    }

    .jPreview-fileType {
      background-color: transparent;
      svg {
        width: 26px;
        height: 32px;
      }
    }

    .previewOther {
      > svg {
        color: #fff;
        width: 122px;
        height: 150px;
      }
    }
      
    @media screen and (max-width: 840px) {
      .jPreview-header .jPreviewButton.forDownload > span { display: block; }
    }

    @media screen and (max-width: 480px) {
      .jPreview-header {
        .jPreviewButton-fileSize, .jPreviewButton.forDownload > span {
          display: none;
        }
      }
    }
  }

  .jfSelect-list {
    background-color: #fff
  }

  // for testimonial widget scheme item dragging
  .schemaItemWrapper {
    z-index: 5000;
  }

  .appNavigation {
    &-popover {
      background-color: #fff;
      max-width: 316px;
      width: 80vw;
      z-index: 12;

      .jfOverflowableList {
        &-item {
          padding: 12px 10px;
          background-color: #fff;
          cursor: pointer;
          justify-content: flex-start;
          fill: #0A1551;

          .isActive, &:hover {
            color: #0099FF;
            fill: #0099FF;

            .jfIconSVG-wrapper > div svg {
              fill: #0099FF;
            }
          }

          .appPageLink {
            width: 100%;

            &-container {
              white-space: nowrap;
              width: 100%;
              overflow: hidden;
              text-overflow: ellipsis;
              transition: .3s;
              display: flex;
              align-items: center;
              gap: 8px;
            }
          }
        }

        &-overflow {
          &-items {
            width: 100%;
          }
        }
      }
    }
  }

  .overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: #0000004d;
    z-index: 1;
    pointer-events: none;
    display: block;
  }

  // for account box wrapper on portal to make sure it doesn't overlap with branding footer
  .jNewHeader-accountBoxWrapper {
    max-height: calc(100vh - 140px);
    max-height: calc(100svh - 140px);
  }

  div.mce-container.mce-panel.mce-floatpanel.mce-window.mce-in .mce-reset .mce-window-body iframe {
    width: 100% !important;
  }

  aside .rightPanelPrimaryAction {
    background-color: #646E7F;
    color: #fff;

    &:hover {
      background-color: #7d8799;
    }

    &:active {
      background-color: #4e5562;
    }
  }

  aside button.customMagnetBtn {
    background-color: var(--jfv-panel-right-item-background);
    &:hover {
      background-color: var(--jfv-panel-right-item-background);
    }
    &:active {
      background-color: var(--jfv-panel-right-item-background);
    }
    border: var(--jfv-panel-right-item-border);
    color: #fff;
  }

  .warningBox .customMagnetBtn {
    width: auto;
    border: 0;
  }

  ${o}
  
  .isAgentApp .isAccountBox {
    display: none;
  }
}
