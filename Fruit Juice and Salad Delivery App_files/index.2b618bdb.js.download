.${er} {
  position: relative !important;
  background-color: transparent !important;
  transition: background-color 0.5s ease-in !important;
  border-radius: 10px;
}

.widgetFieldFillWhiteOverlay {
  position: absolute;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: #b1d3ff33;
  z-index: 4;
  pointer-events: none;
  opacity: 0;
  border-radius: 10px;
  transition: opacity 0.4s ease-in;
}

.widgetFieldFillBorderOverlay {
  position: absolute;
  top: 0;
  left: 0;
  pointer-events: none;
  z-index: 3;
}

.widgetFieldFillBorderRect {
  fill: none;
}

@keyframes widgetFieldFillBounce {
  0% { transform: scale(1); }
  25% { transform: scale(1.04); }
  50% { transform: scale(0.97); }
  75% { transform: scale(1.015); }
  100% { transform: scale(1); }
}
