  width: 100%;
  .magnet-dropdown-list {
    max-height: 400px;
    
    .dropdown-item {
      position: relative;
      &:hover {
        > .item-tooltip {
          display: block;
        }
      }
    }
    
    // Specific styles for disabled items
    .item-disabled {
      opacity: 1;
      color: #7F859C;
    }
    
    // Specific styles for create button
    .create-button {
      opacity: 1;
      &:disabled {
        cursor: pointer;
      }
    }
    
    .divider {
      height: 1px;
      margin: 0px 12px;
      border: 1px solid rgba(227, 229, 245, 0.2);
    }
    
    .create-new-page {
      color: rgba(191, 195, 206, 1);
      font-size: 12px;
    }
     
    .create-button {
      width: 100%;
      height: 2.5rem;
      padding: 0px 10px;
      opacity: 1;
      margin-bottom: 8px;
    }
  }
