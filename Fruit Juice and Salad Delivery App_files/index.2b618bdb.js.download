background-color: #303339;
text-align: right;
z-index: 2;

&:first-letter { text-transform: uppercase; }

&[data-popper-placement^='top']>[data-popper-arrow] {
  bottom: -4px;
}
&[data-popper-placement^='bottom']>[data-popper-arrow] {
  top: -4px;
}
&[data-popper-placement^='left']>[data-popper-arrow] {
  right: -4px;
