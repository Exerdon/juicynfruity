  display: flex;
  border: 1px solid #303339;
  box-shadow: rgba(86, 70, 50, 0.1) 0px 2px 4px;
  background-color: var(--jfv-panel-right-item-background);
  align-items: center;
  border-radius: 4px;
  padding: 0.5em;
  width: 100%;
  // A/B Test: ctAppNameIconModal
  .appNameIconSettingsModal & {
    background-color: #0a1551;
    box-shadow: none;
    border: 0;
  }

  .previewMode-image {
    img {
      display: flex;
      max-width: 116px;
      height: 80px;
      object-fit: contain;
      border-radius: 4px;
    }

    // A/B Test: ctAppNameIconModal
    .appNameIconSettingsModal & {
      border-radius: 4px;
      overflow: hidden;
      display: flex;
    }
  }

  .previewMode-icon {
    width: 80px;
    height: 80px;
    border-radius: 4px;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;

    .jfIconSVG-wrapper {
      width: 100%;
      height: 100%;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 16px;

      svg {
        width: 100%;
        height: 100%;
      }
    }
  }

  .rightSideWrapper {
    flex: 1 1 auto;
    min-width: 0;
    text-align: center;
    overflow: hidden;
    margin-left: 20px;
    color: #fff;

    .previewHint {
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
      text-overflow: ellipsis;
      word-break: break-all;
      text-align: left;
      font-size: 14px;
      line-height: 16px;
      color: #fff;

      & ~ .previewMode-button {
        margin-top: 15px;

        button {
          font-size: 12px;
          border-radius: 4px;
          padding: 7px 16px;
          margin: 0;
          float: left;
        }
      }
    }

    .previewName {
      display: flex;
      align-items: center;
      font-weight: 400;
      font-size: 10px;
      line-height: 16px;
      color: #C8CEED;

      &:hover {
        text-decoration: underline;
      }
    }

    .previewMode-button {
      button {
        display: inline-block;
        cursor: pointer;
        border-radius: 4px;
        background-color: ${f.GY};
        font-weight: 500;
        font-size: 16px;
        line-height: 1;
        padding: 0.875em 3em;
        color: rgb(255, 255, 255);
        border: none;
        outline: none;
        flex-wrap: nowrap;
        margin: 15px;

        &:hover {
          background-color: ${f.KT};
          transition: .1s all ease;
        }
      }
    }

    @media screen and (max-width: 480px) {
      .previewMode-button {
        button {
          font-size: 14px;
          padding: 0.6em 0.875em;
        }
      }
    }
  }

  ${({layout:e})=>"column"===e&&`
    flex-direction: column;
    .previewMode-image {
      img {
        width: 100%;
      }
    }
    .rightSideWrapper {
      width: 100%;
      margin: 0;
      .previewMode-button {
        button {
          border-radius: 4px;
          font-size: 14px;
          flex-wrap: nowrap;
          padding: 7px 16px;
          margin: 0;
          float: left;

          &:hover {
            background-color: ${f.KT};
            transition: .1s all ease;
          }
        }
      }
    }
  `}
